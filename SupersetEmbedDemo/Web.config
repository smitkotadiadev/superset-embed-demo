<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <appSettings>
    <add key="Superset.BaseUrl" value="http://localhost:8088" />
    <add key="Superset.AdminUsername" value="admin" />
    <add key="Superset.AdminPassword" value="admin" />
    <add key="Superset.AuthProvider" value="db" />
    <add key="Superset.GuestTokenTtlSeconds" value="300" />
    <add key="Superset.DemoMode" value="true" />
    <add key="Superset.DemoDashboardUuid" value="abc123-demo-dashboard-uuid" />
    <add key="Superset.EmbeddedSdkUrl" value="https://cdn.jsdelivr.net/npm/@superset-ui/embedded-sdk@0.3.0/bundle/index.js" />
    <add key="Superset.TenantRlsClauseTemplate" value="tenant_id = '{tenantId}'" />
  </appSettings>
  <system.web>
    <compilation debug="true" targetFramework="4.7.2" />
    <httpRuntime targetFramework="4.7.2" maxRequestLength="51200" executionTimeout="600" />
    <pages>
      <namespaces>
        <add namespace="SupersetEmbedDemo" />
        <add namespace="SupersetEmbedDemo.Models" />
        <add namespace="SupersetEmbedDemo.Services" />
      </namespaces>
    </pages>
    <customErrors mode="Off" />
    <httpCookies httpOnlyCookies="true" requireSSL="false" />
  </system.web>
  <system.webServer>
    <validation validateIntegratedModeConfiguration="false" />
    <httpProtocol>
      <customHeaders>
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="X-Frame-Options" value="SAMEORIGIN" />
        <add name="Referrer-Policy" value="strict-origin-when-cross-origin" />
      </customHeaders>
    </httpProtocol>
    <staticContent>
      <remove fileExtension=".woff" />
      <remove fileExtension=".woff2" />
      <mimeMap fileExtension=".woff" mimeType="application/font-woff" />
      <mimeMap fileExtension=".woff2" mimeType="application/font-woff2" />
    </staticContent>
  </system.webServer>
  <system.net>
    <settings>
      <servicePointManager expect100Continue="false" />
    </settings>
  </system.net>
</configuration>
